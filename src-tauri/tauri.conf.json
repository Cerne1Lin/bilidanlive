{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "bilidanlive",
  "version": "0.1.0",
  "identifier": "bilidanlive",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "BiliDanLive",
        "width": 360,
        "height": 660,
        "decorations": false,
        "minWidth": 360,
        "minHeight": 500,
        "transparent": true,
        "windowEffects": {
          "effects": ["hudWindow", "acrylic"],
          "radius": 16,
          "state": "active",
          "color": "#32323234"
        },
        "scrollBarStyle": "fluentOverlay"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
